DJANGO_SETTINGS_MODULE=config.settings.production # Change the production to development 

# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-min-50-chars
DEBUG=False # True in Production
ALLOWED_HOSTS=api.yourdomain.com 
DJANGO_ADMIN_URL=your-secret-admin-path/ # Secure the django admin panel from users maximum secret url use it.

DB_NAME=cpanelusername_zignaturedb
DB_USER=cpanelusername_dbuser
DB_PASSWORD=strongpassword
DB_HOST=127.0.0.1
DB_PORT=5432

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15 # 15 minutes ideal for production
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7 # 7 days for normal and 30days for remember me

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

MEDIA_ROOT=/home/cpanelusername/media
MEDIA_URL=https://api.yourdomain.com/media/

CORS_ALLOWED_ORIGINS=https://yourdomain.vercel.app,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.vercel.app,https://yourdomain.com

# Spectacular / Swagger Settings
SPECTACULAR_TITLE="Zignature Production API"
SPECTACULAR_DESC="Live API documentation for Zignature"
SPECTACULAR_SERVER_URL=https://zignature.com
SPECTACULAR_VERSION=1.2.0