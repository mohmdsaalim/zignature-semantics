DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-secret-key-min-50-chars
DEBUG=False
ALLOWED_HOSTS=api.yourdomain.com
DJANGO_ADMIN_URL=your-secret-admin-path/

DB_NAME=cpanelusername_agencydb
DB_USER=cpanelusername_dbuser
DB_PASSWORD=strongpassword
DB_HOST=127.0.0.1
DB_PORT=5432

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

MEDIA_ROOT=/home/cpanelusername/media
MEDIA_URL=https://api.yourdomain.com/media/

CORS_ALLOWED_ORIGINS=https://yourdomain.vercel.app,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.vercel.app,https://yourdomain.com